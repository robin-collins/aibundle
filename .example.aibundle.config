# Example AIBundle Configuration

# Command Line Options
cli: true
files: "*.rs"
format: "xml" # Options: xml, markdown, json
out: "bundle.md"
source-dir: "./src"

# Output Formats
output_formats:
  - xml
  - markdown
  - json

# Line Numbers
line_numbers: true

# File Selection Patterns
file_patterns:
  - "*"
  - "?"
  - "**"
  - "{}"

# TUI Options
tui:
  selection_methods:
    - space
    - asterisk
  search_filter_features:
    - case_insensitive: true
    - match_file_names: true
  output_options:
    - toggle_formats: true
    - toggle_line_numbers: true
  file_operations:
    - copy_selected_files: true
    - cycle_formats: true
  visual_indicators:
    - operation_in_progress: true
    - operation_complete: true
    - operation_failed: true
